<?xml version="1.0" encoding="utf-8"?>
<!--
  Cleartext is OFF by default for every host. The only exception is the
  loopback addresses, which carry the in-app LiveStreamProxy
  traffic — ExoPlayer talks to NanoHTTPD on 127.0.0.1 to read the
  proxied master/inner playlist. None of this traffic ever leaves the
  device.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">::1</domain>
    </domain-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
